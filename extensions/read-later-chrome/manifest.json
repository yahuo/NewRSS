{
  "manifest_version": 3,
  "name": "NewRSS Read Later",
  "version": "1.1.0",
  "description": "Save the current page into NewRSS Read Later with one click.",
  "permissions": [
    "activeTab",
    "alarms",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "http://newrss.local:8787/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "background.mjs",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png"
    },
    "default_title": "Save to NewRSS Read Later"
  }
}
