{
  "name": "newrss",
  "version": "1.0.0",
  "description": "Self-hosted RSS full-text extraction service — fetches articles, extracts readable content via Readability, and republishes clean RSS feeds for Reeder and other RSS readers",
  "main": "src/server.js",
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning src/server.js",
    "dev": "node --watch --disable-warning=ExperimentalWarning src/server.js",
    "backup:database": "node --disable-warning=ExperimentalWarning scripts/backup-database.js",
    "export:entry": "node --disable-warning=ExperimentalWarning scripts/export-entry.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage \"--test-coverage-exclude=test/**\" --test-coverage-lines=70 --test-coverage-functions=70 --test-coverage-branches=70"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": "^22.16.0 || >=24.0.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.3.0",
    "rss": "^1.2.2",
    "rss-parser": "^3.13.0",
    "undici": "^8.8.0"
  }
}
