{
  "name": "newrss",
  "version": "1.0.0",
  "description": "Self-hosted RSS full-text extraction service — fetches articles, extracts readable content via Readability, and republishes clean RSS feeds for Reeder and other RSS readers",
  "main": "src/server.js",
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning src/server.js",
    "dev": "node --watch --disable-warning=ExperimentalWarning src/server.js",
    "export:entry": "node --disable-warning=ExperimentalWarning scripts/export-entry.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "express": "^5.2.1",
    "jsdom": "^29.0.0",
    "markdown-it": "^14.1.1",
    "rss": "^1.2.2",
    "rss-parser": "^3.13.0"
  }
}
